                                            "example": "Breaking news fetched successfully."
                                        },
                                        "data": {
                                            "properties": {
                                                "news": {
                                                    "type": "array",
                                                    "items": {
                                                        "properties": {
                                                            "id": {
                                                                "type": "integer",
                                                                "example": 1
                                                            },
                                                            "category_id": {
                                                                "type": "integer",
                                                                "example": 2
                                                            },
                                                            "user_id": {
                                                                "type": "integer",
