                                                                    "name": {
                                                                        "type": "string",
                                                                        "example": "Politics"
                                                                    }
                                                                },
                                                                "type": "object"
                                                            },
                                                            "user": {
                                                                "properties": {
                                                                    "id": {
                                                                        "type": "integer",
                                                                        "example": 1
                                                                    },
                                                                    "name": {
                                                                        "type": "string",
                                                                        "example": "Admin"
                                                                    }
                                                                },
                                                                "type": "object"
